<% if(currUser && currUser._id.equals(listing.owner._id)){ %>

<div class="card border-0 shadow-sm rounded-4 mt-4">
  <div class="card-body p-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
      <div>
        <h5 class="fw-bold mb-1">Owner Controls</h5>

        <small class="text-muted"> Manage this listing </small>
      </div>

      <span class="badge bg-success rounded-pill"> Owner </span>
    </div>

    <div class="d-grid gap-3">
      <a
        href="/listings/<%= listing._id %>/edit"
        class="btn btn-dark rounded-pill py-2"
      >
        Edit Listing
      </a>

      <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST">
        <button
          type="submit"
          class="btn btn-outline-danger rounded-pill w-100 py-2"
        >
          Delete Listing
        </button>
      </form>
    </div>
  </div>
</div>

<% } %>
