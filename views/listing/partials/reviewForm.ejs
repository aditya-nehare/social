<% if(currUser){ %>

<div class="card border-0 shadow-sm rounded-4 mt-5">
  <div class="card-body p-4 p-lg-5">
    <div class="mb-4">
      <h3 class="fw-bold mb-1">Leave a Review</h3>

      <p class="text-muted mb-0">Tell other travelers about your experience.</p>
    </div>

    <form action="/listings/<%= listing._id %>/reviews" method="POST">
      <div class="mb-4">
        <div class="d-flex justify-content-between mb-2">
          <label for="rating" class="fw-semibold"> Rating </label>

          <span class="badge bg-dark rounded-pill px-3">
            <span id="ratingValue">3</span>/5
          </span>
        </div>

        <input
          type="range"
          class="form-range"
          min="1"
          max="5"
          step="1"
          value="3"
          id="rating"
          name="review[rating]"
        />

        <div class="d-flex justify-content-between small text-muted">
          <span>Poor</span>
          <span>Average</span>
          <span>Excellent</span>
        </div>
      </div>
      <div class="mb-4">
        <label for="comment" class="form-label fw-semibold">
          Your Review
        </label>

        <textarea
          id="comment"
          class="form-control rounded-4"
          rows="5"
          name="review[comment]"
          placeholder="What did you like? What could be improved?"
          required
        ></textarea>
      </div>
      <div class="text-end">
        <button class="btn btn-dark rounded-pill px-5 py-2">
          Submit Review
        </button>
      </div>
    </form>
  </div>
</div>

<% } %>
