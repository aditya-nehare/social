<% if(currUser){ %>

<div class="mt-5 pt-4 border-top">
  <h3 class="fw-bold mb-1">Leave a Review</h3>

  <p class="text-secondary mb-4">
    Share your experience with future travelers.
  </p>

  <form action="/listings/<%= listing._id %>/reviews" method="POST">
    <div class="mb-4">
      <div class="d-flex justify-content-between align-items-center mb-2">
        <label for="rating" class="fw-semibold"> Rating </label>

        <span class="fw-bold fs-5"> <span id="ratingValue">3</span>/5 </span>
      </div>

      <input
        type="range"
        class="form-range"
        min="1"
        max="5"
        step="1"
        value="3"
        id="rating"
        name="review[rating]"
      />

      <div class="d-flex justify-content-between text-secondary small">
        <span>Poor</span>
        <span>Average</span>
        <span>Excellent</span>
      </div>
    </div>
    <div class="mb-4">
      <label for="comment" class="form-label fw-semibold"> Review </label>

      <textarea
        class="form-control"
        id="comment"
        rows="5"
        name="review[comment]"
        placeholder="Tell others about your stay..."
        required
      ></textarea>
    </div>

    <button class="btn btn-dark px-4">Submit Review</button>
  </form>
</div>

<% } %>
