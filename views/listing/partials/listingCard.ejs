<div class="container py-5">
  <h2 class="fw-bold mb-2"><%= listing.title %></h2>
  <p class="text-secondary mb-4">
    <i class="fa-solid fa-location-dot me-1"></i>
    <%= listing.location %>, <%= listing.country %>
  </p>
  <img
    src="<%= listing.image.url %>"
    class="img-fluid rounded-3 mb-5"
    style="height: 520px; width: 100%; object-fit: cover"
    alt="<%= listing.title %>"
  />
  <div class="row g-5">
    <div class="col-lg-8">
      <div class="border-bottom pb-4">
        <h4 class="fw-semibold">Hosted by <%= listing.owner.username %></h4>
        <p class="text-secondary mb-0">
          Comfortable stay • Great location • Verified listing
        </p>
      </div>

      <div class="py-4 border-bottom">
        <h5 class="fw-bold mb-3">About this place</h5>
        <p class="text-secondary lh-lg"><%= listing.description %></p>
      </div>

      <% if(currUser && currUser._id.equals(listing.owner._id)){ %>
      <div class="pt-4">
        <a
          href="/listings/<%= listing._id %>/edit"
          class="btn btn-dark me-2 px-4"
        >
          Edit
        </a>
        <form
          action="/listings/<%= listing._id %>?_method=DELETE"
          method="POST"
          class="d-inline"
        >
          <button class="btn btn-outline-dark px-4">Delete</button>
        </form>
      </div>

      <% } %>
    </div>
    <div class="col-lg-4">
      <div class="card shadow-sm sticky-top" style="top: 90px">
        <div class="card-body p-4">
          <h3 class="fw-bold mb-4">
            ₹<%= listing.price.toLocaleString("en-IN") %>
            <small class="fs-6 text-muted fw-normal"> / night </small>
          </h3>

          <div class="d-grid mb-3">
            <button class="btn btn-dark py-2">Reserve</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
