<% layout('/layouts/Boilerplate.ejs') %>

<div class="container py-4">
  <h2 class="mb-4 fw-bold">All Listings</h2>

  <div class="row row-cols-lg-3 row-cols-md-2 row-cols-1 g-4">
    <% for (let listing of listings) { %>
    <div class="col">
      <div class="card h-100 shadow-sm border-0 rounded-5">
        <img
          src="<%= listing.image %>"
          loading="lazy"
          class="card-img-top rounded-top-4"
          alt="listing image"
          style="height: 220px; object-fit: cover"
        />

        <div class="card-body">
          <h5 class="card-title fw-bold"><%= listing.title %></h5>
          <p class="card-text text-muted mb-2">
            <%= listing.description.length > 80 ?
            listing.description.substring(0, 80) + "..." : listing.description
            %>
          </p>

          <p class="mb-1">
            <strong>Location:</strong> <%= listing.location %>, <%=
            listing.country %>
          </p>

          <p class="mb-3 text-success fw-semibold fs-5">
            <%= listing.price.toLocaleString("en-IN") %>$ / night
          </p>

          <a
            href="/listings/<%= listing._id %>"
            class="btn btn-dark rounded-pill px-4"
          >
            View
          </a>
        </div>
      </div>
    </div>
    <% } %>
  </div>
</div>
