<% layout("/layouts/Boilerplate.ejs") %>

<div class="container py-5">
  <div class="text-center mb-5">
    <h1 class="display-5 fw-bold">Find your next stay</h1>

    <p class="text-muted fs-5">
      Explore unique homes, apartments, and unforgettable experiences.
    </p>
  </div>

  <div class="row text-center mb-5">
    <div class="col-md-4">
      <h3 class="fw-bold"><%= listings.length %>+</h3>
      <p class="text-muted">Listings</p>
    </div>

    <div class="col-md-4">
      <h3 class="fw-bold">100+</h3>
      <p class="text-muted">Cities</p>
    </div>

    <div class="col-md-4">
      <h3 class="fw-bold">24/7</h3>
      <p class="text-muted">Support</p>
    </div>
  </div>

  <div class="row g-4">
    <% listings.forEach(listing=>{ %>

    <div class="col-xl-4 col-md-6">
      <a
        href="/listings/<%= listing._id %>"
        class="text-decoration-none text-dark"
      >
        <div class="card border-0 shadow-sm rounded-4 h-100 listing-card">
          <div class="position-relative">
            <img
              src="<%= listing.image %>"
              class="card-img-top"
              style="height: 250px; object-fit: cover"
              alt="<%= listing.title %>"
            />

            <span
              class="badge bg-light text-dark position-absolute top-0 end-0 m-3 rounded-pill px-3 py-2"
            >
              $<%= listing.price.toLocaleString("en-IN") %>/night
            </span>
          </div>

          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start">
              <div>
                <h5 class="fw-bold mb-1"><%= listing.title %></h5>

                <small class="text-muted">
                  📍 <%= listing.location %>, <%= listing.country %>
                </small>
              </div>

              <span class="badge bg-warning text-dark"> ★ 4.8 </span>
            </div>

            <p class="text-muted mt-3 mb-0">
              <%= listing.description.length>70 ?
              listing.description.substring(0,70)+"..." : listing.description %>
            </p>
          </div>
        </div>
      </a>
    </div>

    <% }) %>
  </div>
</div>
