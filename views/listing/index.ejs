<% layout("/layouts/Boilerplate.ejs") %>

<div class="container py-5">
  <div class="container mb-5">
    <div class="row align-items-center">
      <!-- Categories -->
      <div class="col-lg-9">
        <div class="d-flex overflow-auto gap-4 py-2 category-bar">
          <a
            href="/listings?category=Trending"
            class="text-decoration-none text-center text-dark category-item"
          >
            <i class="fa-solid fa-fire fa-xl mb-2"></i>
            <div class="small">Trending</div>
          </a>

          <a
            href="/listings?category=Beach"
            class="text-decoration-none text-center text-dark category-item"
          >
            <i class="fa-solid fa-umbrella-beach fa-xl mb-2"></i>
            <div class="small">Beach</div>
          </a>

          <a
            href="/listings?category=Mountains"
            class="text-decoration-none text-center text-dark category-item"
          >
            <i class="fa-solid fa-mountain fa-xl mb-2"></i>
            <div class="small">Mountains</div>
          </a>

          <a
            href="/listings?category=Camping"
            class="text-decoration-none text-center text-dark category-item"
          >
            <i class="fa-solid fa-campground fa-xl mb-2"></i>
            <div class="small">Camping</div>
          </a>

          <a
            href="/listings?category=Lake"
            class="text-decoration-none text-center text-dark category-item"
          >
            <i class="fa-solid fa-water fa-xl mb-2"></i>
            <div class="small">Lake</div>
          </a>

          <a
            href="/listings?category=City"
            class="text-decoration-none text-center text-dark category-item"
          >
            <i class="fa-solid fa-city fa-xl mb-2"></i>
            <div class="small">City</div>
          </a>

          <a
            href="/listings?category=Luxury"
            class="text-decoration-none text-center text-dark category-item"
          >
            <i class="fa-solid fa-gem fa-xl mb-2"></i>
            <div class="small">Luxury</div>
          </a>

          <a
            href="/listings?category=Cabins"
            class="text-decoration-none text-center text-dark category-item"
          >
            <i class="fa-solid fa-house fa-xl mb-2"></i>
            <div class="small">Cabins</div>
          </a>
        </div>
      </div>

      <div class="col-lg-3 mt-3 mt-lg-0">
        <form
          class="d-flex justify-content-lg-end"
          action="/listings"
          method="GET"
        >
          <div
            class="input-group"
            style="
              border: 1px solid #ddd;
              border-radius: 50px;
              overflow: hidden;
            "
          >
            <input
              type="text"
              class="form-control border-0"
              name="search"
              placeholder="Search..."
            />

            <button class="btn btn-danger px-3">
              <i class="fa-solid fa-magnifying-glass"></i>
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <div class="row g-2">
    <% listings.forEach(listing => { %>

    <div class="col-xl-3 col-lg-4 col-md-6">
      <a
        href="/listings/<%= listing._id %>"
        class="text-decoration-none text-dark"
      >
        <div class="listing-card h-120">
          <img
            src="<%= listing.image.url %>"
            alt="<%= listing.title %>"
            class="listing-img"
          />

          <div class="p-3">
            <h6 class="fw-bold mb-1"><%= listing.title %></h6>

            <p class="text-secondary small mb-2">
              <%= listing.location %>, <%= listing.country %>
            </p>
          </div>
        </div>
      </a>
    </div>

    <% }) %>
  </div>
</div>
