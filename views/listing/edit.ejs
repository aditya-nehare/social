<% layout('/layouts/Boilerplate.ejs') %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8 col-md-10">
      <div class="card shadow-lg border-0 rounded-5 p-4">
        <h2 class="fw-bold mb-4 text-center">Edit Listing</h2>
        <div class="card border-0 rounded-5 overflow-hidden">
          <img
            src="<%= listing.image %>"
            loading="lazy"
            class="card-img-top"
            alt="listing image"
            style="height: 400px; object-fit: cover"
          />
        </div>

        <form
          method="post"
          action="/listings/<%= listing._id %>?_method=PATCH"
          enctype="multipart/form-data"
        >
          <div class="mb-3 mt-3">
            <label for="title" class="form-label fw-semibold">Title</label>
            <input
              type="text"
              id="title"
              name="listing[title]"
              class="form-control rounded-3"
              placeholder="Enter title"
              value="<%= listing.title %>"
              required
            />
            <div class="valid-feedback">Looks Good</div>
          </div>

          <div class="mb-3">
            <label for="description" class="form-label fw-semibold"
              >Description</label
            >
            <textarea
              id="description"
              name="listing[description]"
              class="form-control rounded-3"
              rows="4"
              placeholder="Enter description"
              required
            >
<%= listing.description %></textarea
            >
          </div>

          <div class="mb-3">
            <label for="image" class="form-label fw-semibold">Image Link</label>
            <input
              type="file"
              id="image"
              name="listing[image]"
              class="form-control rounded-3"
              placeholder="Enter image URL"
              value="<%= listing.image %>"
            />
          </div>

          <div class="mb-3">
            <label for="location" class="form-label fw-semibold"
              >Location</label
            >
            <input
              type="text"
              id="location"
              name="listing[location]"
              class="form-control rounded-3"
              placeholder="Enter location"
              value="<%= listing.location %>"
              required
            />
            <div class="valid-feedback">Nice Location</div>
          </div>

          <div class="mb-3">
            <label for="country" class="form-label fw-semibold">Country</label>
            <input
              type="text"
              id="country"
              name="listing[country]"
              class="form-control rounded-3"
              placeholder="Enter country"
              value="<%= listing.country %>"
              required
            />
          </div>

          <div class="mb-4">
            <label for="price" class="form-label fw-semibold">Price</label>
            <input
              type="number"
              id="price"
              name="listing[price]"
              class="form-control rounded-3"
              placeholder="Enter price"
              value="<%= listing.price %>"
              required
            />
            <div class="invalid-feedback">Price should be in Number</div>
          </div>

          <div class="d-flex justify-content-between">
            <a
              href="/listings/<%= listing._id %>"
              class="btn btn-outline-secondary rounded-pill px-4"
            >
              Cancel
            </a>
            <button type="submit" class="btn btn-dark rounded-pill px-4">
              Update Listing
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
