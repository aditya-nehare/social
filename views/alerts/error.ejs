<% layout('/layouts/Boilerplate.ejs') %>

<div class="container d-flex align-items-center justify-content-center vh-100">
  <div class="text-center" style="max-width: 650px">
    <h1
      class="fw-bold mb-3"
      style="font-size: 7rem; letter-spacing: -3px; line-height: 1"
    >
      <%= statusCode %>
    </h1>

    <h2 class="fw-bold mb-3" style="font-size: 2rem"><%= message %></h2>

    <p
      class="text-secondary fst-italic mb-5"
      style="font-size: 1.05rem; line-height: 1.8"
    >
      The page you're looking for doesn't exist or something went wrong.
    </p>

    <a
      href="/"
      class="btn btn-dark px-5 py-2 fw-semibold"
      style="border-radius: 0; font-size: 1rem"
    >
      ← Go Home
    </a>
  </div>
</div>
