<% layout("/layouts/Boilerplate.ejs") %>

<!-- Hero -->
<section class="hero-section text-white">
  <div class="container">
    <div class="row align-items-center min-vh-100">
      <div class="col-lg-6">
        <h1 class="display-3 fw-bold">Find your perfect stay.</h1>

        <p class="lead my-4">
          Discover unique homes, apartments and unforgettable experiences around
          the world.
        </p>

        <a href="/listings" class="btn btn-light btn-lg rounded-pill px-4 me-3">
          Explore Stays
        </a>

        <% if(!currUser){ %>

        <a
          href="/signup"
          class="btn btn-outline-light btn-lg rounded-pill px-4"
        >
          Become a Host
        </a>

        <% } %>
      </div>
    </div>
  </div>
</section>

<!-- Features -->

<section class="py-5 bg-light">
  <div class="container">
    <div class="row text-center g-4">
      <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100 rounded-4">
          <div class="card-body p-4">
            <div class="display-5 mb-3">🏡</div>

            <h4>Unique Stays</h4>

            <p class="text-muted">
              Explore beautiful homes carefully selected for every traveler.
            </p>
          </div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100 rounded-4">
          <div class="card-body p-4">
            <div class="display-5 mb-3">💳</div>

            <h4>Affordable Prices</h4>

            <p class="text-muted">
              Great places at prices that fit every budget.
            </p>
          </div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100 rounded-4">
          <div class="card-body p-4">
            <div class="display-5 mb-3">⭐</div>

            <h4>Trusted Reviews</h4>

            <p class="text-muted">
              Real reviews from real guests help you choose confidently.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->

<section class="py-5 text-center">
  <div class="container">
    <h2 class="fw-bold">Ready for your next adventure?</h2>

    <p class="text-muted mb-4">
      Thousands of amazing places are waiting for you.
    </p>

    <a href="/listings" class="btn btn-dark btn-lg rounded-pill px-5">
      Browse Listings
    </a>
  </div>
</section>
